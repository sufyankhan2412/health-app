PORT=5000

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/healthapp?retryWrites=true&w=majority

JWT_SECRET=your_strong_jwt_secret_here
JWT_EXPIRES_IN=7d

# Gmail SMTP (use App Password, not your regular password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_16_char_app_password
MAIL_FROM=ExpatCares <your_email@gmail.com>

# Frontend URL (set this on your hosting platform)
CLIENT_URL=https://your-app.vercel.app
